# =============================================================
# GovTech Intelligence Suite – Environment Variables
# Copy this file to .env and fill in your values.
# On Vercel, set these in the Vercel dashboard (Project > Settings > Environment Variables).
# =============================================================

# -----------------------------------------------------------------
# Database
# For local development you can use SQLite:
#   DATABASE_URL="file:./db/govtech.db"
# For Vercel (production) use a hosted PostgreSQL database, e.g.:
#   Vercel Postgres, Neon, Supabase, PlanetScale…
#   DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Note: when switching to PostgreSQL, change the `provider` in
#       prisma/schema.prisma from "sqlite" to "postgresql" and run
#       `npx prisma migrate deploy`.
# -----------------------------------------------------------------
DATABASE_URL="file:./db/govtech.db"

# -----------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_URL must match the deployed URL on Vercel.
# On Vercel, this is set automatically via VERCEL_URL, but you can
# override it here for a custom domain.
# Generate NEXTAUTH_SECRET with:  openssl rand -base64 32
# -----------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-long"

# -----------------------------------------------------------------
# AI Services (optional – for AI report generation)
# -----------------------------------------------------------------
ZAI_API_KEY=""
ZAI_API_URL="https://api.zai.com"

# -----------------------------------------------------------------
# Email / SMTP (optional – for notifications)
# -----------------------------------------------------------------
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="noreply@govtech.ai"

# -----------------------------------------------------------------
# Application
# -----------------------------------------------------------------
NODE_ENV="development"
