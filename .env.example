# ==============================================
# GovTech AI — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in the values
# For Vercel: Add these in Project Settings > Environment Variables

# Database (SQLite for dev, PostgreSQL recommended for production)
DATABASE_URL="file:./db/govtech.db"

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-key-at-least-32-chars"

# Optional: AI Services
# ZAI_API_KEY="your-api-key"
# ZAI_API_URL="https://api.zai.com"
