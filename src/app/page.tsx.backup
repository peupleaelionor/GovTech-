                <div>
                  <div className="flex items-center gap-2 mb-4">
                    <Building2 className="h-6 w-6" />
                    <span className="font-bold">GovTech AI</span>
                  </div>
                  <p className="text-sm text-gray-600">
                    {currentLang === 'fr' 
                      ? 'La solution de gouvernance IA pour les nations africaines.'
                      : 'AI governance solution for African nations.'}
                  </p>
                </div>

                <div>
                  <h3 className="font-semibold mb-4">
                    {currentLang === 'fr' ? 'Pays Ciblés' : 'Target Countries'}
                  </h3>
                  <ul className="space-y-2 text-sm text-gray-600">
                    <li>🇨🇲 Cameroun</li>
                    <li>🇨🇩 RD Congo</li>
                    <li>🇬🇦 Gabon</li>
                    <li>🇨🇬 Congo Brazzaville</li>
                    <li>🇨🇮 Côte d'Ivoire</li>
                    <li>🇰🇪 Kenya</li>
                  </ul>
                </div>

                <div>
                  <h3 className="font-semibold mb-4">
                    {currentLang === 'fr' ? 'Fonctionnalités' : 'Features'}
                  </h3>
                  <ul className="space-y-2 text-sm text-gray-600">
                    <li>Analytics africains</li>
                    <li>Optimisation budgétaire</li>
                    <li>Management diaspora</li>
                    <li>Performance optimisée</li>
                  </ul>
                </div>

                <div>
                  <h3 className="font-semibold mb-4">
                    {currentLang === 'fr' ? 'Contact' : 'Contact'}
                  </h3>
                  <ul className="space-y-2 text-sm text-gray-600">
                    <li>enterprise@govtech.ai</li>
                    <li>+237 123 456 789</li>
                    <li>Yamoussoukro, Cameroun</li>
                  </ul>
                </div>
              </div>

              <div className="border-t mt-8 pt-8 text-center text-sm text-gray-600">
                <p>© 2024 GovTech AI. {currentLang === 'fr' ? 'Tous droits réservés.' : 'All rights reserved.'}</p>
              </div>
            </div>
