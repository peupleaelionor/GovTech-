                          {country.code === 'CM' && '🇨🇲'}
                          {country.code === 'CD' && '🇨🇩'}
                          {country.code === 'GA' && '🇬🇦'}
                          {country.code === 'CG' && '🇨🇬'}
                          {country.code === 'CI' && '🇨🇮'}
                          {country.code === 'SN' && '🇸🇳'}
                          {country.code === 'NG' && '🇳🇬'}
                          {country.code === 'KE' && '🇰🇪'}
                        </div>
                        <CardTitle className="text-lg">{country.name}</CardTitle>
                        <CardDescription className="text-sm">
                          {currentLang === 'fr' ? country.nameFr : country.nameEn}
