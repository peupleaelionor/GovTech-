                    { icon: <BarChart3 />, title: "Analytics Avancés", desc: "Tableaux de bord avec métriques de développement africaines" },
                    { icon: <Shield />, title: "Sécurité Niveau Gouvernemental", desc: "Conformité aux standards internationaux" },
                    { icon: <TrendingUp />, title: "Optimisation Budgétaire", desc: "Algorithmes d'optimisation des dépenses" },
                    { icon: <Globe />, title: "Diaspora Management", desc: "Suivi des investissements et transferts" },
                    { icon: <Building2 />, title: "Projets Infrastructur", desc: "Suivi des projets de développement" },
                    { icon: <Zap />, title: "Performance Optimisée", desc: "Animations fluides et temps réel" },
