                          <div className="flex justify-between">
                            <span className="text-gray-600">Population:</span>
                            <span className="font-medium">{(country.development.population / 1000000).toFixed(1)}M</span>
                          </div>
                          <div className="flex justify-between">
                            <span className="text-gray-600">IDH:</span>
                            <span className="font-medium">{country.development.humanDevelopmentIndex}</span>
                          </div>
                        </div>
                      </CardContent>
